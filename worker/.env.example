# ============ Worker server ============
PORT=8080
# Where your frontend runs — used to redirect back after login AND for CORS.
APP_URL=

# ============ Twitch app ============
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret
TWITCH_REDIRECT_URI=https://your-worker.up.railway.app/auth/twitch/callback

# ============ Kick app ============
KICK_CLIENT_ID=your_kick_client_id
KICK_CLIENT_SECRET=your_kick_client_secret
KICK_REDIRECT_URI=https://your-worker.up.railway.app/auth/kick/callback

